diff --git a/src/PrologotEngine.hpp b/src/PrologotEngine.hpp
new file mode 100644
index 0000000..b53e0eb
--- /dev/null
+++ b/src/PrologotEngine.hpp
@@ -0,0 +1,64 @@
+#pragma once
+
+#include <SWI-Prolog.h>
+#include <godot_cpp/classes/ref_counted.hpp>
+
+using namespace godot;
+
+/**
+ * @class PrologotEngine
+ * @brief Class encapsulating a SWI-Prolog per-thread engine.
+ *
+ * This class wraps the SWI-Prolog PL_engine_t and exposes it to GDScript,
+ * allowing users to execute Prolog in multiple threads.
+ */
+class PrologotEngine: public RefCounted
+{
+    GDCLASS(PrologotEngine, RefCounted)
+
+public:
+
+    /**
+     * @brief Constructs a new PrologotEngine instance.
+     *
+     * Creates a new engine instance.
+     */
+    PrologotEngine();
+
+    /**
+     * @brief Destructs the PrologotEngine instance.
+     *
+     * Ensures proper cleanup of the Prolog engine.
+     */
+    ~PrologotEngine();
+
+	void set_active_for_this_thread();
+	static void deactivate();
+	static Ref<PrologotEngine> get_current();
+
+protected:
+
+    /**
+     * @brief Binds all C++ methods to GDScript.
+     *
+     * This method is called by Godot's class system to register all methods
+     * that should be accessible from GDScript. Methods are organized by
+     * category for better code organization.
+     */
+    static void _bind_methods();
+
+private:
+
+	friend class Prologot;
+
+	PrologotEngine(PL_engine_t p_engine);
+
+	PL_engine_t m_engine = nullptr;
+
+	/**
+	 * @brief The global engine instance used as default.
+	 */
+	static Ref<PrologotEngine> m_global_engine;
+
+	static thread_local Ref<PrologotEngine> t_current_engine;
+};

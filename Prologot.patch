+// =============================================================================
+// Engine Manipulation
+// =============================================================================
+
+void PrologotEngine::_bind_methods()
+{
+    ClassDB::bind_method(D_METHOD("set_active_for_this_thread"),
+                         &PrologotEngine::set_active_for_this_thread);
+    ClassDB::bind_static_method("PrologotEngine", D_METHOD("deactivate"),
+                         &PrologotEngine::deactivate);
+    ClassDB::bind_static_method("PrologotEngine", D_METHOD("get_current"),
+                         &PrologotEngine::get_current);
+}
+
+void PrologotEngine::set_active_for_this_thread() {
+    PL_set_engine(m_engine, nullptr);
+}
+
+void PrologotEngine::deactivate() {
+    PL_set_engine(nullptr, nullptr);
+    if (t_current_engine) {
+        t_current_engine = nullptr;
+    }
+}
+
+Ref<PrologotEngine> PrologotEngine::get_current() {
+    PL_engine_t eng = PL_current_engine();
+    if (!eng)
+        return nullptr;
+    Ref<PrologotEngine> inst = t_current_engine;
+    if (inst.is_valid() and inst->m_engine == eng)
+        return inst;
+    return nullptr;
+}
+
+PrologotEngine::PrologotEngine() {
+    ERR_FAIL_COND_MSG(!Prologot::get_singleton() or !Prologot::get_singleton()->is_initialized(), "Prologot must be initialized");
+
+    m_engine = PL_create_engine(nullptr);
+    ERR_FAIL_NULL(m_engine);
+}
+
+PrologotEngine::PrologotEngine(PL_engine_t eng) {
+    m_engine = eng;
+    ERR_FAIL_NULL(m_engine);
+}
+
+PrologotEngine::~PrologotEngine() {
+    if (t_current_engine == this) {
+        deactivate();
+    }
+
+    if (m_engine) {
+        PL_destroy_engine(m_engine);
+    }
+}
